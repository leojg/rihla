# Rihla credentials - copy to .env and fill in. .env is gitignored.

# --- Travelpayouts (primary data source: free, self-serve, redistribution-licensed) ---
# Sign up at https://www.travelpayouts.com, connect the Aviasales program, and copy the
# token from the API tools page. Used by scripts/probe_coverage.py and the upcoming
# Travelpayouts fetcher. Leave blank to run offline against the built-in MockFetcher.
TRAVELPAYOUTS_TOKEN=

# --- SerpApi / Google Flights (BYO-key: real-data baseline; dev / self-host only) ------
# https://serpapi.com - 250 free searches/month. Used as the coverage-probe baseline and
# (later) a self-host fetcher. Keep OUT of any public hosted deployment - it scrapes Google.
SERPAPI_KEY=

# --- Profile: which sources are allowed -------------------------------------------------
# local  (default) = every source whose key is set, incl. SerpApi BYOK
# hosted           = redistribution-licensed sources only (Travelpayouts); SerpApi disabled
# mock             = force the offline MockFetcher (no network)
RIHLA_PROFILE=local

# Amadeus Self-Service is retired (portal decommissioned 2026-07-17) - do not use.
